HOST=127.0.0.1
PORT=3000
RUST_LOG=arena_server=debug,tower_http=debug

# PostgreSQL
DATABASE_URL=postgres://arena:localdev@localhost:5432/arena
# DB_MAX_CONNECTIONS=10
# DB_MIN_CONNECTIONS=1

# Rate Limiting (per client IP)
# RATE_LIMIT_BURST_SIZE=10
# RATE_LIMIT_PER_SECOND=5
# RATE_LIMIT_CLEANUP_SECS=60

# CORS — comma-separated allowed origins (empty = allow all)
# CORS_ALLOWED_ORIGINS=https://arena.example.com,https://staging.arena.example.com

# Admin — promote user with this email to admin on startup
# ADMIN_EMAIL=you@example.com
# PROSODY_AGENT_API_KEY=your-secret-api-key   # Bootstrap ilakkanam-scorer evaluator agent (requires ADMIN_EMAIL)
# MEANING_AGENT_API_KEY=your-secret-api-key   # Bootstrap meaning-scorer evaluator agent (requires ADMIN_EMAIL)
